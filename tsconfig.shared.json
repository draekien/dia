{
  "$schema": "./node_modules/@effect/tsgo/schema.json",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": [],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["src/shared/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
